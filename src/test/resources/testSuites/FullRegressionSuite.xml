<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<suite name="Full Regression Suite" verbose="1">
	<parameter name="browser" value="chrome"></parameter>
    <listeners>
        <listener class-name="com.ankit.listeners.TestListener"/>
    </listeners>

	<test name="Valid Login Test">
		<parameter name="username" value="student"></parameter>
		<parameter name="password" value="Password123"></parameter>


		<groups>
			<run>
				<include name="positive"></include>
			</run>
		</groups>

		<classes>
			<class name="com.ankit.tests.login.LoginTests">
			</class>
		</classes>
	</test>

	<test name="Invalid Username Test">
		<parameter name="username" value="studentxxx"></parameter>
		<parameter name="password" value="Password123"></parameter>
		<parameter name="expectedErrorMessage" value="Your username is invalid!"></parameter>

		<classes>
			<class name="com.ankit.tests.login.LoginTests">
				<methods>
					<include name="validateErrorForInvalidLogin"></include>
				</methods>
			</class>
		</classes>
	</test>


	<test name="Invalid Password Test">
		<parameter name="username" value="student"></parameter>
		<parameter name="password" value="Password1234"></parameter>
		<parameter name="expectedErrorMessage" value="Your password is invalid!"></parameter>

		<classes>
			<class name="com.ankit.tests.login.LoginTests">
				<methods>
					<include name="validateErrorForInvalidLogin"></include>
				</methods>
			</class>
		</classes>
	</test>

</suite>